{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dev Launch Kit",
  "version": "0.1.0",
  "identifier": "com.h1dr0n.rct-launch-kit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:51420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dev Launch Kit",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://raw.githubusercontent.com/h1dr0nn/rct-launch-kit/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBRTMxQzhGMjlEMDlDQUEKUldTcW5OQXBqeHpqR3R3aGRLQ2tWaVNJWE8wVERiU3dsU3BrVldsdnYzVXEzMnpmRzk5Y2xaK08K"
    }
  }
}